# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Optional: set to your current ngrok HTTPS URL so the server prints the exact
# webhook URLs to configure in Shopify Admin and Meta App on startup.
# Get this URL by running: ngrok http 3000
# Example: PUBLIC_URL=https://nonexaggerated-arduous-isiah.ngrok-free.dev
PUBLIC_URL=

# ─── Database ────────────────────────────────────────────────
# Local PostgreSQL (no password needed for system user)
DATABASE_URL=postgresql://YOUR_SYSTEM_USER@localhost:5432/qwertees_whatsapp

# ─── Meta WhatsApp Cloud API ──────────────────────────────────
META_ACCESS_TOKEN=your_permanent_access_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_WABA_ID=your_whatsapp_business_account_id_here
META_APP_SECRET=your_app_secret_here
META_VERIFY_TOKEN=your_custom_webhook_verify_token_here

# ─── Shopify ──────────────────────────────────────────────────
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_admin_api_access_token_here
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_signing_secret_here

# ─── Web Push / VAPID (iOS PWA + desktop push notifications) ─
# Generate your keys once with this command (run from server/ after npm install):
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2))"
# Then paste the output values below.
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
# Must be mailto: or your site URL — identifies you to push relay servers.
VAPID_EMAIL=mailto:your-email@example.com

# Also expose the public key to the frontend so it can subscribe:
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ─── Production (Railway / hosting) ─────────────────────────
# Set CLIENT_URL on the backend service so Express allows CORS from the frontend.
# Example: CLIENT_URL=https://automation.example.com
CLIENT_URL=

# ─── Client (Vite) ───────────────────────────────────────────
# Leave these UNSET in development — the Vite proxy routes /api and /socket.io
# to the backend automatically, and works from any device on the same network.
# Only uncomment and set these for production deployments on Railway.
# VITE_API_URL=https://api.example.com/api
# VITE_WS_URL=https://api.example.com

# ─── Authentication ──────────────────────────────────────────
# Single-user login credentials for the admin interface.
# Username for login (plaintext).
AUTH_USERNAME=akshay
# bcrypt hash of the admin password (rounds=12). NEVER store plaintext.
# Generate: node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(console.log)"
# Run from server/ directory after npm install.
AUTH_PASSWORD_HASH=your_bcrypt_hash_here
# JWT signing secret — must be at least 32 characters. Generate: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
# JWT token expiry — e.g. "7d", "24h". Defaults to 7 days.
JWT_EXPIRES_IN=7d
